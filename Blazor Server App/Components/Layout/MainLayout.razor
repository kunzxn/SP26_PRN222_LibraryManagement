@inherits LayoutComponentBase

<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
    <div class="layout-container flex h-full grow flex-col">
        <Navbar ActivePage="Browse" />

        <main class="flex flex-1 justify-center py-8">
            <div class="layout-content-container flex flex-col max-w-[1200px] flex-1 px-4 md:px-10">
                @Body
            </div>
        </main>

        <!-- Footer -->
        <footer class="bg-white border-t border-primary/10 py-10 px-10">
            <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="col-span-1 md:col-span-1">
                    <div class="flex items-center gap-4 text-primary mb-6">
                        <div class="size-6 flex items-center justify-center bg-primary/10 rounded">
                            <span class="material-symbols-outlined text-primary text-lg">auto_stories</span>
                        </div>
                        <h2 class="text-slate-900 text-base font-bold">UniLibrary</h2>
                    </div>
                    <p class="text-sm text-slate-500">The central digital hub for all university learning materials and research resources.</p>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 mb-4">Resources</h4>
                    <ul class="space-y-2 text-sm text-slate-500">
                        <li><a class="hover:text-primary" href="#">E-Books</a></li>
                        <li><a class="hover:text-primary" href="#">Journal Archives</a></li>
                        <li><a class="hover:text-primary" href="#">Research Papers</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 mb-4">Support</h4>
                    <ul class="space-y-2 text-sm text-slate-500">
                        <li><a class="hover:text-primary" href="#">Help Center</a></li>
                        <li><a class="hover:text-primary" href="#">Librarian Chat</a></li>
                        <li><a class="hover:text-primary" href="#">Tutorials</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 mb-4">Mobile App</h4>
                    <p class="text-xs text-slate-500 mb-4">Take the library anywhere with our mobile app.</p>
                    <div class="flex gap-2">
                        <div class="bg-slate-900 px-3 py-1.5 rounded flex items-center gap-2 cursor-pointer border border-slate-700">
                            <span class="material-symbols-outlined text-white text-xl">phone_iphone</span>
                            <div class="flex flex-col">
                                <span class="text-[8px] text-slate-400 leading-none">Download on</span>
                                <span class="text-[10px] text-white font-bold leading-none">App Store</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="max-w-[1200px] mx-auto pt-8 mt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-xs text-slate-400">© 2024 University Library Services. All rights reserved.</p>
                <div class="flex gap-6">
                    <a class="text-xs text-slate-400 hover:text-primary" href="#">Privacy Policy</a>
                    <a class="text-xs text-slate-400 hover:text-primary" href="#">Terms of Service</a>
                </div>
            </div>
        </footer>
    </div>
</div>

@code {
    [Inject] private Blazor_Server_App.Services.UserSession UserSession { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !UserSession.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login", true);
        }
        await Task.CompletedTask;
    }
}
