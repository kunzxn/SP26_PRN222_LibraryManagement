@page "/login"
@page "/"
@layout Layout.EmptyLayout
@rendermode InteractiveServer

<PageTitle>University Library System - Login</PageTitle>

<div class="bg-background-light font-display min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <!-- Logo/Header Section -->
        <div class="flex flex-col items-center mb-8">
            <div class="bg-primary/10 p-3 rounded-xl mb-4">
                <span class="material-symbols-outlined text-primary text-4xl">local_library</span>
            </div>
            <h1 class="text-slate-900 text-3xl font-bold tracking-tight text-center">University Library System</h1>
            <p class="text-slate-500 mt-2 text-center">
                @(IsRegisterMode ? "Create your student account." : "Welcome back! Please enter your details.")
            </p>
        </div>

        <!-- Login / Register Card -->
        <div class="bg-white shadow-xl shadow-primary/5 rounded-xl border border-slate-200 p-8">
            <div class="space-y-6">
                @if (IsRegisterMode)
                {
                    <!-- Full Name Input (Register only) -->
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700" for="fullname">Full Name</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-slate-400 text-lg">person</span>
                            </div>
                            <input @bind="FullName"
                                   class="block w-full pl-10 pr-3 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                                   id="fullname" placeholder="John Doe" type="text" />
                        </div>
                    </div>
                }

                <!-- Email Input -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700" for="email">Email Address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 text-lg">mail</span>
                        </div>
                        <input @bind="Email"
                               class="block w-full pl-10 pr-3 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                               id="email" placeholder="name@university.edu" type="email" />
                    </div>
                </div>

                <!-- Password Input -->
                <div class="space-y-2">
                    <div class="flex items-center justify-between">
                        <label class="block text-sm font-semibold text-slate-700" for="password">Password</label>
                        @if (!IsRegisterMode)
                        {
                            <a class="text-sm font-medium text-primary hover:underline" href="#">Forgot password?</a>
                        }
                    </div>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 text-lg">lock</span>
                        </div>
                        <input @bind="Password"
                               class="block w-full pl-10 pr-3 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                               id="password" placeholder="••••••••" type="password" />
                    </div>
                </div>

                @if (IsRegisterMode)
                {
                    <!-- Confirm Password -->
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700" for="confirmpassword">Confirm Password</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-slate-400 text-lg">lock</span>
                            </div>
                            <input @bind="ConfirmPassword"
                                   class="block w-full pl-10 pr-3 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                                   id="confirmpassword" placeholder="••••••••" type="password" />
                        </div>
                    </div>
                }

                <!-- Error / Success Message -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="flex items-center gap-2 p-3 rounded-lg bg-red-50 border border-red-100">
                        <span class="material-symbols-outlined text-red-600 text-sm">error</span>
                        <p class="text-red-600 text-xs font-medium">@ErrorMessage</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="flex items-center gap-2 p-3 rounded-lg bg-green-50 border border-green-100">
                        <span class="material-symbols-outlined text-green-600 text-sm">check_circle</span>
                        <p class="text-green-600 text-xs font-medium">@SuccessMessage</p>
                    </div>
                }

                <!-- Submit Button -->
                <button @onclick="HandleSubmit" disabled="@IsProcessing"
                        class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-4 rounded-lg transition-colors focus:ring-4 focus:ring-primary/30 flex items-center justify-center gap-2 disabled:opacity-50">
                    @if (IsProcessing)
                    {
                        <span>Processing...</span>
                    }
                    else if (IsRegisterMode)
                    {
                        <span>Create Account</span>
                        <span class="material-symbols-outlined text-lg">person_add</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                        <span class="material-symbols-outlined text-lg">login</span>
                    }
                </button>

                <!-- SSO Alternative (Login only) -->
                @if (!IsRegisterMode)
                {
                    <div class="relative my-6">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-slate-200"></div>
                        </div>
                        <div class="relative flex justify-center text-sm">
                            <span class="px-2 bg-white text-slate-500">Or continue with</span>
                        </div>
                    </div>
                    <button class="w-full flex items-center justify-center gap-3 px-4 py-3 border border-slate-200 rounded-lg bg-white text-slate-700 hover:bg-slate-50 transition-colors font-medium" type="button">
                        <span class="material-symbols-outlined text-primary">school</span>
                        University SSO
                    </button>
                }
            </div>
        </div>

        <!-- Footer -->
        <footer class="mt-8 text-center space-y-4">
            <p class="text-slate-500 text-sm">
                @if (IsRegisterMode)
                {
                    <span>Already have an account? </span>
                    <a @onclick="ToggleMode" @onclick:preventDefault class="text-primary font-semibold hover:underline cursor-pointer" href="#">Sign In</a>
                }
                else
                {
                    <span>Don't have an account? </span>
                    <a @onclick="ToggleMode" @onclick:preventDefault class="text-primary font-semibold hover:underline cursor-pointer" href="#">Register</a>
                }
            </p>
            <div class="flex justify-center gap-6 text-xs text-slate-400">
                <a class="hover:text-primary" href="#">Help Center</a>
                <a class="hover:text-primary" href="#">Privacy Policy</a>
                <a class="hover:text-primary" href="#">Library Terms</a>
            </div>
        </footer>
    </div>

    <!-- Decorative Elements -->
    <div class="fixed top-0 left-0 w-full h-full -z-10 overflow-hidden pointer-events-none opacity-20">
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary rounded-full mix-blend-multiply filter blur-3xl opacity-30"></div>
        <div class="absolute top-1/2 -right-24 w-80 h-80 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    </div>
</div>

@code {
    [Inject] private AuthService AuthService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private UserSession UserSession { get; set; } = null!;

    private string Email = "";
    private string Password = "";
    private string FullName = "";
    private string ConfirmPassword = "";
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool IsProcessing = false;
    private bool IsRegisterMode = false;

    private void ToggleMode()
    {
        IsRegisterMode = !IsRegisterMode;
        ErrorMessage = null;
        SuccessMessage = null;
    }

    private async Task HandleSubmit()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        IsProcessing = true;

        try
        {
            if (IsRegisterMode)
            {
                // Validate registration
                if (string.IsNullOrWhiteSpace(FullName) || string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
                {
                    ErrorMessage = "Please fill in all fields.";
                    return;
                }

                if (Password != ConfirmPassword)
                {
                    ErrorMessage = "Passwords do not match.";
                    return;
                }

                if (Password.Length < 6)
                {
                    ErrorMessage = "Password must be at least 6 characters.";
                    return;
                }

                var (success, message) = await AuthService.RegisterAsync(FullName, Email, Password);
                if (success)
                {
                    SuccessMessage = message;
                    IsRegisterMode = false;
                    Password = "";
                    ConfirmPassword = "";
                    FullName = "";
                }
                else
                {
                    ErrorMessage = message;
                }
            }
            else
            {
                // Validate login
                if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
                {
                    ErrorMessage = "Please enter your email and password.";
                    return;
                }

                var (success, message, session, user) = await AuthService.LoginAsync(Email, Password);
                if (success && session != null && user != null)
                {
                    // Save user session state
                    UserSession.Login(user.ID, user.FullName, user.Role);

                    // Navigate based on role
                    if (session.Role == "Admin")
                        Navigation.NavigateTo("/dashboard", false);
                    else
                        Navigation.NavigateTo("/booksearch", false);
                }
                else
                {
                    ErrorMessage = message;
                }
            }
        }
        catch (Exception)
        {
            ErrorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            IsProcessing = false;
        }
    }
}
