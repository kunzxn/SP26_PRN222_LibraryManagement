@* Book Card Component *@
<div class="group bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-xl transition-all flex flex-col @(BookData.Quantity == 0 ? "opacity-75" : "")">
    <div class="aspect-[3/4] bg-slate-200 relative overflow-hidden @(BookData.Quantity == 0 ? "grayscale" : "")">
        @if (BookData.Quantity == 0)
        {
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                <span class="bg-red-600 text-white text-[10px] uppercase font-bold px-3 py-1 rounded-full">Out of Stock</span>
            </div>
        }
        else
        {
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
                <span class="bg-primary/90 text-white text-[10px] uppercase font-bold px-2 py-1 rounded tracking-wider">@BookData.Category</span>
            </div>
            <div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-4xl">visibility</span>
            </div>
        }
        <div class="w-full h-full bg-gradient-to-br from-primary/30 to-primary/60 flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-6xl">menu_book</span>
        </div>
    </div>
    <div class="p-5 flex flex-col flex-1">
        <div class="flex-1">
            <h4 class="text-slate-900 font-bold leading-tight mb-1 group-hover:text-primary transition-colors">@BookData.Title</h4>
            <p class="text-slate-500 text-sm mb-4">@BookData.Author</p>
        </div>
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
            <div class="flex flex-col">
                <span class="text-[10px] uppercase text-slate-400 font-bold">Available</span>
                @if (BookData.Quantity > 5)
                {
                    <span class="text-sm font-semibold text-green-600">@BookData.Quantity Copies</span>
                }
                else if (BookData.Quantity > 0)
                {
                    <span class="text-sm font-semibold text-amber-600">@BookData.Quantity Copies</span>
                }
                else
                {
                    <span class="text-sm font-semibold text-red-600">0 Copies</span>
                }
            </div>
            @if (BookData.Quantity > 0)
            {
                <button @onclick="() => OnBorrow.InvokeAsync(BookData)"
                        class="bg-primary text-white text-xs font-bold py-2 px-4 rounded-lg hover:scale-105 transition-transform">
                    Borrow
                </button>
            }
            else
            {
                <button class="bg-slate-200 text-slate-500 text-xs font-bold py-2 px-4 rounded-lg cursor-not-allowed" disabled>
                    Unavailable
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Book BookData { get; set; } = null!;
    [Parameter] public EventCallback<Book> OnBorrow { get; set; }
}
