@* Admin Sidebar Component *@
<aside class="w-64 bg-white border-r border-slate-200 flex flex-col">
    <div class="p-6 flex items-center gap-3">
        <div class="bg-primary rounded-lg p-2 text-white">
            <span class="material-symbols-outlined text-2xl">auto_stories</span>
        </div>
        <div>
            <h1 class="text-lg font-bold leading-none">UniLibrary</h1>
            <p class="text-xs text-slate-500">Admin Portal</p>
        </div>
    </div>

    <nav class="flex-1 px-4 py-4 space-y-1">
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ActivePage == "Dashboard" ? "bg-primary/10 text-primary font-medium" : "text-slate-600 hover:bg-slate-100") transition-colors"
           href="/dashboard">
            <span class="material-symbols-outlined text-[22px]">dashboard</span>
            <span>Dashboard</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ActivePage == "ManageBooks" ? "bg-primary/10 text-primary font-medium" : "text-slate-600 hover:bg-slate-100") transition-colors"
           href="/managebooks">
            <span class="material-symbols-outlined text-[22px]">menu_book</span>
            <span>Manage Books</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ActivePage == "BorrowRecords" ? "bg-primary/10 text-primary font-medium" : "text-slate-600 hover:bg-slate-100") transition-colors"
           href="/borrowrecords">
            <span class="material-symbols-outlined text-[22px]">history_edu</span>
            <span>Borrow Records</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 hover:bg-slate-100 transition-colors"
           href="#">
            <span class="material-symbols-outlined text-[22px]">group</span>
            <span>Students</span>
        </a>
    </nav>

    <div class="p-4 border-t border-slate-200">
        <a href="/logout" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
            <span class="material-symbols-outlined text-[22px]">logout</span>
            <span>Logout</span>
        </a>
    </div>
</aside>

@code {
    [Parameter] public string ActivePage { get; set; } = "";
    [Inject] private Blazor_Server_App.Services.UserSession UserSession { get; set; } = null!;
}
