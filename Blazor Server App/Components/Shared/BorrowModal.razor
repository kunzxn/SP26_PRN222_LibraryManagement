@* Borrow Confirmation Modal *@
@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4">
        <div class="w-full max-w-[480px] bg-white rounded-xl shadow-2xl overflow-hidden border border-slate-200">
            <!-- Modal Header -->
            <div class="px-6 pt-6 pb-2 flex justify-between items-start">
                <div>
                    <h2 class="text-xl font-bold tracking-tight">Confirm Borrowing</h2>
                    <p class="text-slate-500 text-sm mt-1">Please review the details before confirming.</p>
                </div>
                <button @onclick="OnClose" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Book Info -->
            <div class="px-6 py-4">
                <div class="flex items-center gap-4 bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <div class="bg-gradient-to-br from-primary/30 to-primary/60 rounded shadow-sm w-16 aspect-[3/4] flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-2xl">menu_book</span>
                    </div>
                    <div class="flex flex-col justify-center">
                        <p class="text-slate-900 text-base font-semibold leading-snug line-clamp-1">@SelectedBook?.Title</p>
                        <p class="text-primary text-sm font-medium leading-normal line-clamp-1">@SelectedBook?.Author</p>
                        <div class="flex items-center gap-1 mt-1">
                            <span class="material-symbols-outlined text-[14px] text-green-500">check_circle</span>
                            <span class="text-[12px] text-green-600 font-medium">Available for loan</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details -->
            <div class="px-6 py-2 space-y-4">
                <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-sm">calendar_today</span>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Borrow Date</span>
                    </div>
                    <span class="text-sm font-semibold text-slate-900">@DateTime.Now.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-sm">event_repeat</span>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Due Date (14 Days)</span>
                    </div>
                    <span class="text-sm font-semibold text-slate-900">@DateTime.Now.AddDays(14).ToString("MMM dd, yyyy")</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-sm">info</span>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Loan Policy</span>
                    </div>
                    <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded">Standard Academic</span>
                </div>
            </div>

            <!-- Warning Notice -->
            <div class="px-6 mt-4">
                <div class="bg-amber-50 border border-amber-100 p-3 rounded-lg flex gap-3">
                    <span class="material-symbols-outlined text-amber-600 text-sm">warning</span>
                    <p class="text-[12px] text-amber-700 leading-relaxed">
                        Late returns are subject to penalties. You can renew this item once if there are no pending requests.
                    </p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="px-6 mt-3">
                    <div class="bg-red-50 border border-red-100 p-3 rounded-lg flex items-center gap-2">
                        <span class="material-symbols-outlined text-red-600 text-sm">error</span>
                        <p class="text-red-600 text-xs font-medium">@ErrorMessage</p>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="px-6 mt-3">
                    <div class="bg-green-50 border border-green-100 p-3 rounded-lg flex items-center gap-2">
                        <span class="material-symbols-outlined text-green-600 text-sm">check_circle</span>
                        <p class="text-green-600 text-xs font-medium">@SuccessMessage</p>
                    </div>
                </div>
            }

            <!-- Footer Buttons -->
            <div class="p-6 flex gap-3">
                <button @onclick="OnClose"
                        class="flex-1 h-11 px-5 rounded-lg border border-slate-200 hover:bg-slate-50 text-slate-700 text-sm font-bold transition-colors">
                    Cancel
                </button>
                <button @onclick="HandleConfirm" disabled="@IsProcessing"
                        class="flex-[2] h-11 px-5 rounded-lg bg-primary hover:bg-primary/90 text-white text-sm font-bold shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-2 disabled:opacity-50">
                    @if (IsProcessing)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-sm">assignment_return</span>
                        <span>Confirm Borrow</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Book? SelectedBook { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Book> OnConfirm { get; set; }

    private bool IsProcessing = false;
    private string? ErrorMessage;
    private string? SuccessMessage;

    private async Task HandleConfirm()
    {
        if (SelectedBook == null) return;
        IsProcessing = true;
        ErrorMessage = null;
        SuccessMessage = null;
        await OnConfirm.InvokeAsync(SelectedBook);
        IsProcessing = false;
    }
}
